{
  "name": "eswat2",
  "version": "2.1.273",
  "description": "A personal card for Richard Hess (@eswat2)",
  "main": "/bin/card.js",
  "bin": {
    "eswat2": "bin/card.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eswat2/eswat2.git"
  },
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8",
  "scripts": {
    "bump": "bumpp patch --commit --tag --push --yes",
    "card": "node ./bin/card.js",
    "release": "pnpm bump && pnpm build && pnpm card",
    "preinstall": "npx only-allow pnpm",
    "build": "node build.mjs",
    "dev": "pnpm build && pnpm card",
    "lint": "standard",
    "test": "echo skipping tests...",
    "open": "npx eswat2@latest"
  },
  "keywords": [
    "card",
    "npm",
    "npm card",
    "npx",
    "npx card",
    "business card"
  ],
  "author": "Tierney Cyren <hello@bnb.im> (http://bnb.im)",
  "license": "MIT",
  "files": [
    "bin/card.js",
    "bin/output"
  ],
  "devDependencies": {
    "boxen": "8.0.1",
    "bumpp": "11.1.0",
    "only-allow": "1.2.2",
    "picocolors": "1.1.1",
    "standard": "17.1.2",
    "yoctocolors": "2.1.2"
  }
}
