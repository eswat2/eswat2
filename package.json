{
  "name": "eswat2",
  "version": "2.1.239",
  "description": "A personal card for Richard Hess (@eswat2)",
  "main": "/bin/card.js",
  "bin": {
    "eswat2": "./bin/card.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/eswat2/eswat2.git"
  },
  "packageManager": "pnpm@11.0.8+sha512.4c4097e1dd2d42372c4e7fa5a791ff28fc75a484c7ac192e64b1df0fdef17594ba982f9b4fed9adfb3c757846f565b799b2763fb3733d1de1bcb82cf46684912",
  "scripts": {
    "bump": "bumpp patch --commit --tag --push --yes",
    "card": "node ./bin/card.js",
    "release": "pnpm bump && pnpm build && pnpm card && pnpm publish",
    "preinstall": "npx only-allow pnpm",
    "build": "node build.mjs",
    "dev": "pnpm build && pnpm card",
    "lint": "standard",
    "test": "echo skipping tests...",
    "open": "npx eswat2@latest"
  },
  "keywords": [
    "card",
    "npm",
    "npm card",
    "npx",
    "npx card",
    "business card"
  ],
  "author": "Tierney Cyren <hello@bnb.im> (http://bnb.im)",
  "license": "MIT",
  "files": [
    "bin/card.js",
    "bin/output"
  ],
  "devDependencies": {
    "boxen": "8.0.1",
    "bumpp": "11.1.0",
    "only-allow": "1.2.2",
    "picocolors": "1.1.1",
    "standard": "17.1.2",
    "yoctocolors": "2.1.2"
  }
}
