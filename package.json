{
  "name": "eswat2",
  "version": "2.1.275",
  "description": "A personal card for Richard Hess (@eswat2)",
  "main": "/bin/card.js",
  "bin": {
    "eswat2": "bin/card.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eswat2/eswat2.git"
  },
  "packageManager": "pnpm@11.12.0+sha512.820a6fbd0d9f04c226638002aead1e45340a9139dd5dc077c1d83ef44aa2481c8eb6637b4c9aa696a3c7e35ba818e49cf27213e5f2b91138d09b7a3e26e898ba",
  "scripts": {
    "bump": "bumpp patch --commit --tag --push --yes",
    "card": "node ./bin/card.js",
    "release": "pnpm bump && pnpm build && pnpm card",
    "preinstall": "npx only-allow pnpm",
    "build": "node build.mjs",
    "dev": "pnpm build && pnpm card",
    "lint": "standard",
    "test": "echo skipping tests...",
    "open": "npx eswat2@latest"
  },
  "keywords": [
    "card",
    "npm",
    "npm card",
    "npx",
    "npx card",
    "business card"
  ],
  "author": "Tierney Cyren <hello@bnb.im> (http://bnb.im)",
  "license": "MIT",
  "files": [
    "bin/card.js",
    "bin/output"
  ],
  "devDependencies": {
    "boxen": "8.0.1",
    "bumpp": "11.1.0",
    "only-allow": "1.2.2",
    "picocolors": "1.1.1",
    "standard": "17.1.2",
    "yoctocolors": "2.1.2"
  }
}
